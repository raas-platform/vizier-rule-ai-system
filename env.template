# VizierAI Rule Validation API - 프로덕션 환경 설정

# ====== 기본 설정 ======
ENVIRONMENT=production  # development, staging, production
DEBUG=false

# ====== 서버 설정 ======
HOST=0.0.0.0
PORT=8000
WORKERS=4
# WORKERS=4  # CPU 코어 수 * 2 권장
LOG_LEVEL=info  # debug, info, warning, error

# ====== 보안 설정 ======
# CORS 설정 (프로덕션에서는 특정 도메인만 허용)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOWED_HOSTS=yourdomain.com,app.yourdomain.com,localhost

# Secret Key (임의의 긴 문자열)
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# ====== AI 서비스 API 키 ======
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# ====== 데이터베이스 설정 ======
DATABASE_URL=sqlite:///./vizierai.db

# PostgreSQL (프로덕션 권장)
# DATABASE_URL=postgresql://user:password@localhost:5432/vizierai_db

# ====== 캐싱 설정 ======
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your_redis_password_here
CACHE_TTL=3600
# CACHE_TTL=3600  # 1시간 (초)

# ====== 모니터링 및 로깅 ======
SENTRY_DSN=your_sentry_dsn_here  # 오류 추적
LOG_FILE=logs/vizierai.log
MAX_LOG_SIZE=50MB
LOG_BACKUP_COUNT=5

# ====== 성능 설정 ======
MAX_REQUEST_SIZE=10485760
# MAX_REQUEST_SIZE=10485760  # 10MB
REQUEST_TIMEOUT=30
AI_TIMEOUT=60
MAX_CONCURRENT_REQUESTS=100

# ====== AI 모델 설정 ======
DEFAULT_MODEL=gpt-3.5-turbo
FALLBACK_MODEL=claude-3-haiku-20240307
MAX_TOKENS=4000
TEMPERATURE=0.7

# ====== Rate Limiting ======
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# ====== SSL/TLS 설정 ======
SSL_CERT_PATH=/etc/ssl/certs/yourdomain.crt
SSL_KEY_PATH=/etc/ssl/private/yourdomain.key

# ====== Nginx 설정 (선택사항) ======
NGINX_CLIENT_MAX_BODY_SIZE=10m
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024

# ====== Docker 설정 ======
COMPOSE_PROJECT_NAME=vizierai
DOCKER_REGISTRY=your-registry.com/vizierai

# ====== 백업 설정 ======
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 매일 새벽 2시
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket

# ====== 알림 설정 ======
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@yourdomain.com
EMAIL_PASSWORD=your_email_password_here
ADMIN_EMAIL=admin@yourdomain.com

# ====== 헬스체크 설정 ======
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3 